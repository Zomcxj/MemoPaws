/* ═══════════════════════════════════════════════════════════════
   components.css — Design System Component Definitions
   Auto-extracted from preview/component-*.html
   DO NOT EDIT MANUALLY — regenerate via extract-components-css.mjs
   ═══════════════════════════════════════════════════════════════ */

/* ── Badge ─────────────────────────────────────────────────── */
/* @anatomy
   <span class="badge filled">Essay</span> <span class="badge filled">Editorial</span> <span class="badge filled is-disabled" aria-disabled="true">Essay</span>
*/
.preview{width:min(100%,760px);margin:0 auto;display:grid;gap:clamp(24px,4vw,32px)}
.section{display:grid;gap:14px}
.badge{display:inline-flex;align-items:center;justify-content:center;min-height:32px;padding:0 calc(var(--spacing)*3.5);border-radius:var(--radius);font:600 12px/1 var(--font-sans);letter-spacing:.01em;white-space:nowrap;transition:transform .16s ease,box-shadow .16s ease,background-color .16s ease,color .16s ease,border-color .16s ease}
.badge:hover{transform:translateY(-1px)}
.filled{background:var(--primary);color:var(--primary-foreground);border:1px solid transparent;box-shadow:var(--shadow-xs)}
.filled:hover{box-shadow:var(--shadow-sm)}
.muted{background:var(--muted);color:var(--foreground);border:1px solid transparent}
.outline{background:var(--popover);color:var(--foreground);border:1px solid var(--border)}
.is-disabled{pointer-events:none;box-shadow:none}
.filled.is-disabled{background:var(--secondary);color:var(--muted-foreground);border-color:var(--border)}
.muted.is-disabled{background:var(--card);color:var(--muted-foreground);border-color:transparent}
.outline.is-disabled{background:var(--background);color:var(--muted-foreground)}

/* ── Button ────────────────────────────────────────────────── */
/* @anatomy
   <span class="label">Primary</span> <div class="examples"> <button class="btn primary" type="button">Start a new chat</button> <button class="btn primary" type="button" disabled>Start a new chat</button> </div>
*/
.preview{width:min(100%,760px);margin:0 auto;display:grid;gap:clamp(24px,4vw,32px)}
.section{display:grid;gap:14px}
.examples{display:flex;flex-wrap:wrap;gap:12px 14px;align-items:center;padding:clamp(18px,3vw,24px);border:1px solid var(--border);border-radius:calc(var(--radius) + 4px);background:var(--popover);box-shadow:var(--shadow-xs)}
.btn{display:inline-flex;align-items:center;justify-content:center;min-height:44px;padding:0 18px;border:1px solid transparent;border-radius:var(--radius);box-shadow:var(--shadow-sm);background:transparent;color:var(--foreground);font:600 14px/1.1 var(--font-sans);white-space:nowrap;transition:background-color .16s ease,color .16s ease,border-color .16s ease,box-shadow .16s ease}
.btn:hover,.btn:focus-visible{box-shadow:var(--shadow-md)}
.btn:focus-visible{outline:2px solid var(--ring);outline-offset:2px}
.btn:disabled{cursor:not-allowed;box-shadow:none}
.primary{background:var(--primary);color:var(--primary-foreground)}
.primary:disabled{background:var(--secondary);color:var(--muted-foreground);border-color:var(--border)}
.secondary{background:var(--secondary);color:var(--foreground);border-color:var(--border)}
.secondary:disabled{background:var(--background);color:var(--muted-foreground);border-color:var(--border)}
.ghost{background:transparent;color:var(--foreground);box-shadow:none}
.ghost:hover,.ghost:focus-visible{background:var(--muted)}
.ghost:disabled{background:transparent;color:var(--muted-foreground);border-color:transparent}

/* ── Card ──────────────────────────────────────────────────── */
/* @anatomy
   <article class="card"> <p class="eyebrow">Reading Card</p> <h2 class="title">Summarize this chapter</h2> <p class="body">Claude Design System frames long-form AI assistant reading with soft elevation, calm spacing, and editorial rhythm.</p> </article> <article class="card disabled" aria-disabled="true"> <p class="eyebrow">Reading Card</p> <h2 class="title">Context locked</h2> <p class="body">Th...
*/
.preview{width:min(100%,860px);margin:0 auto;display:grid;gap:clamp(24px,4vw,32px)}
.section{display:grid;gap:14px}
.card{width:100%;height:100%;display:flex;flex-direction:column;padding:18px;border:1px solid var(--border);border-radius:var(--radius);background:var(--popover);box-shadow:var(--shadow-sm);transition:transform .16s ease,box-shadow .16s ease,border-color .16s ease}
.card:hover{transform:translateY(-1px);box-shadow:var(--shadow-lg)}
.eyebrow{margin:0 0 10px;font:600 10px/1.2 var(--font-serif);letter-spacing:.12em;text-transform:uppercase;color:var(--muted-foreground)}
.title{margin:0 0 10px;font:600 21px/1.18 var(--font-sans);color:var(--foreground)}
.body{margin:0;flex:1;font-size:14px;line-height:1.6;color:var(--secondary-foreground)}
.disabled{background:var(--card);box-shadow:none;border-color:var(--border);pointer-events:none}
.disabled .eyebrow{color:var(--muted-foreground)}
.disabled .title{color:var(--foreground)}
.disabled .body{color:var(--muted-foreground)}
.sunken{background:var(--card);box-shadow:none}
.sunken .body{color:var(--foreground)}
.emphasis{background:var(--foreground);color:var(--background);border-color:transparent;box-shadow:var(--shadow-xl)}
.emphasis .eyebrow{color:var(--secondary)}
.emphasis .body,.emphasis .title{color:var(--background)}

/* ── Chat Bubble ───────────────────────────────────────────── */
/* @anatomy
   <div class="bubble user"> <span class="meta">You · now</span> <p class="copy">Recommend a writer for light reading.</p>
*/
.preview{width:min(100%,760px);margin:0 auto;display:grid;gap:clamp(24px,4vw,32px)}
.section{display:grid;gap:14px}
.bubble{display:grid;gap:8px;max-width:280px;padding:calc(var(--spacing)*3.5) calc(var(--spacing)*4);border-radius:calc(var(--radius) + 2px);box-shadow:var(--shadow-sm)}
.user{background:var(--primary);color:var(--primary-foreground)}
.assistant{background:var(--popover);color:var(--card-foreground);border:1px solid var(--border)}
.meta{display:block;font:500 11px/1.3 var(--font-sans);letter-spacing:.01em}
.user .meta{color:var(--primary-foreground);opacity:.78}
.assistant .meta{color:var(--muted-foreground)}
.copy{margin:0;font-size:14px;line-height:1.6}
.disabled{box-shadow:none}
.user.disabled{background:var(--secondary);color:var(--secondary-foreground)}
.user.disabled .meta{color:var(--secondary-foreground);opacity:1}
.assistant.disabled{background:var(--card);color:var(--muted-foreground)}
.thread{display:grid;gap:12px;width:min(100%,360px);padding:calc(var(--spacing)*4);background:var(--popover);border:1px solid var(--border);border-radius:calc(var(--radius) + 6px);box-shadow:var(--shadow-sm)}

/* ── Input ─────────────────────────────────────────────────── */
/* @anatomy
   <input class="field" type="text" placeholder="Search components…" aria-label="Claude Design System search input"> <input class="field" type="text" placeholder="Search components…" aria-label="Claude Design System search input disabled" disabled>
*/
.preview{width:min(100%,760px);margin:0 auto;display:grid;gap:clamp(24px,4vw,32px)}
.section{display:grid;gap:14px}
.field,.bar{flex:1 1 280px;min-width:220px;height:40px;border:1px solid var(--border);border-radius:var(--radius);background:var(--background);box-shadow:var(--shadow-sm)}
.field{padding:0 calc(var(--spacing)*3);color:var(--foreground);font:inherit}
.field::placeholder,.bar input::placeholder{color:var(--muted-foreground)}
.field:focus,.bar:focus-within{outline:none;border-color:var(--ring);box-shadow:var(--shadow-sm)}
.field:disabled,.bar.disabled{background:var(--card);color:var(--muted-foreground);box-shadow:none}
.bar{display:flex;align-items:center;gap:8px;padding:0 calc(var(--spacing)*3);background:var(--card);border-color:transparent}
.bar input{flex:1;min-width:0;border:0;background:transparent;color:inherit;font:inherit;outline:none}
.dot{width:8px;height:8px;border-radius:var(--radius-full);background:var(--muted-foreground);opacity:.5}

/* ── Navigation ────────────────────────────────────────────── */
/* @anatomy
   <nav class="tabs" aria-label="Navigation tabs"> <button class="tab active" type="button">Web</button> <button class="tab" type="button">Mobile</button> <button class="tab" type="button">Library</button> <button class="tab" type="button" disabled>Syncing</button> </nav>
*/
.preview{width:min(100%,860px);margin:0 auto;display:grid;gap:clamp(24px,4vw,32px)}
.section{display:grid;gap:14px}
.tabs,.rail,.bottom-nav{border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow-xs)}
.tabs{display:flex;gap:6px;flex-wrap:wrap;max-width:100%;padding:6px;background:var(--card)}
.tab,.item,.nav-item{appearance:none;border:1px solid transparent;background:transparent;color:var(--muted-foreground);font:600 13px/1.1 var(--font-sans);cursor:pointer;transition:background-color .16s ease,color .16s ease,border-color .16s ease,box-shadow .16s ease}
.tab{padding:11px 15px;border-radius:calc(var(--radius) - 6px)}
.tab:hover,.nav-item:hover{background:var(--popover);color:var(--foreground)}
.item:hover{background:var(--sidebar-accent);color:var(--foreground)}
.tab:focus-visible,.item:focus-visible,.nav-item:focus-visible{outline:2px solid var(--ring);outline-offset:2px}
.tab.active,.nav-item.active{background:var(--popover);color:var(--foreground);border-color:var(--border);box-shadow:var(--shadow-xs)}
.tab.active{box-shadow:var(--shadow-sm)}
.tab:disabled,.item:disabled,.nav-item:disabled{cursor:not-allowed;box-shadow:none;background:transparent;color:var(--muted-foreground)}
.brand{margin:0 0 12px;font:600 11px/1.2 var(--font-serif);letter-spacing:.14em;text-transform:uppercase;color:var(--sidebar-foreground)}
.stack{display:grid;gap:8px}
.item{width:100%;padding:12px 13px;border-radius:calc(var(--radius) - 8px);text-align:left;color:var(--sidebar-foreground);background:transparent}
.item.active{background:var(--popover);color:var(--foreground);border-color:var(--sidebar-border);box-shadow:var(--shadow-xs)}
.bottom-nav{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;width:min(100%,420px);padding:8px;background:var(--popover)}
.nav-item{display:grid;gap:4px;justify-items:center;padding:12px 10px;border-radius:calc(var(--radius) - 6px)}
    </style>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4.3.1/dist/index.global.js"></script>
    <script src="https://unpkg.com/lucide@1.8.0/dist/umd/lucide.min.js"></script>
    <style type="text/tailwindcss">
  @theme inline {
    --color-foreground: var(--card-foreground);
  }
  @layer base {
    body { background: var(--card-background); color: var(--card-foreground); }
    td, th { @apply break-words; word-break: break-all; word-break: auto-phrase; }
    th { @apply whitespace-nowrap; }
  }
    </style>
    <style>
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      [data-icon] {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        -webkit-mask-size: contain;
        mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        mask-repeat: no-repeat;
        -webkit-mask-position: center;
        mask-position: center;
        background-color: currentColor;
      }
    </style>
</head>
<body class="min-h-screen font-sans antialiased">
    <main>
    </main>
    <script>lucide.createIcons();</script>
</body>
</html>
